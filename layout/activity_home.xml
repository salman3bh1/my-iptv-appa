<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:paddingHorizontal="15dp"
        android:background="#0C0C0C">

        <LinearLayout
            android:id="@+id/layoutProfileInfo"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_profile"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:id="@+id/tvCurrentUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salman"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="06:25 AM"
                    android:textColor="#888888"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="260dp"
            android:layout_height="42dp"
            android:layout_centerInParent="true"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="2dp">

            <ImageButton
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/nav_bg"
                android:src="@drawable/ic_home"
                app:tint="#FFFFFF"
                android:padding="9dp"
                android:scaleType="fitCenter"
                android:contentDescription="@null" />

            <ImageButton
                android:id="@+id/navSeries"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_series"
                app:tint="#FFFFFF"
                android:padding="9dp"
                android:scaleType="fitCenter"
                android:contentDescription="@null" />

            <ImageButton
                android:id="@+id/navMovies"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_movie"
                app:tint="#FFFFFF"
                android:padding="9dp"
                android:scaleType="fitCenter"
                android:contentDescription="@null" />

            <ImageButton
                android:id="@+id/navLive"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_live"
                app:tint="#FFFFFF"
                android:padding="9dp"
                android:scaleType="fitCenter"
                android:contentDescription="@null" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnSearch"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_search"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#FFFFFF"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="@null" />

            <ImageButton
                android:id="@+id/btnFavorites"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_favorite"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#FFFFFF"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="10dp"
                android:contentDescription="@null" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btnAppInfo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#222222"
                app:cardElevation="0dp"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="i"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textSize="18sp" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </RelativeLayout>

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar" />

</RelativeLayout>
