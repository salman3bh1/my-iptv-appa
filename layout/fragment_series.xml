<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:fillViewport="true"
    android:focusable="true"
    android:clickable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <RelativeLayout
            android:id="@+id/layoutFeatured"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginBottom="25dp">

            <ImageView
                android:id="@+id/ivFeaturedBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_movie" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/black"
                android:alpha="0.65" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentBottom="true"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvFeaturedTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:shadowColor="#000000"
                    android:shadowRadius="8"
                    android:shadowDx="2"
                    android:shadowDy="2"/>

                <TextView
                    android:id="@+id/tvFeaturedDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fetching series overview from server..."
                    android:textColor="#DDDDDD"
                    android:textSize="14sp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:layout_marginVertical="12dp"
                    android:shadowColor="#000000"
                    android:shadowRadius="6"
                    android:shadowDx="1"
                    android:shadowDy="1"/>

                <Button
                    android:id="@+id/btnFeaturedPlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶ Play Now"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    android:paddingHorizontal="24dp"/>
            </LinearLayout>

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutSeriesCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>